# Copy to .env in project root. Never commit real secrets.

# OpenAI (AI chat on server)
OPENAI_API_KEY=

# PostHog (frontend analytics)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=your_posthog_project_token
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SMTP — Google Workspace / Gmail (use App Password for SMTP_USER account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@tidyzon.com
SMTP_PASS=your-google-app-password

MAIL_FROM=support@tidyzon.com
MAIL_FROM_NAME=Tidyzon Support
MAIL_TO=support@tidyzon.com

PORT=3001
